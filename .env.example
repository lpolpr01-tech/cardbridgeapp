# ============================================================
# Finance Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Plaid (https://dashboard.plaid.com) ──────────────────────────────────────
# Sign up for a free Plaid account and get your sandbox keys from:
# https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_plaid_client_id
# For sandbox: use PLAID_SANDBOX_SECRET (checked first by the server)
PLAID_SANDBOX_SECRET=your_plaid_sandbox_secret
# For development/production: use PLAID_SECRET instead
# PLAID_SECRET=your_plaid_dev_or_prod_secret
# "sandbox" | "development" | "production"
PLAID_ENV=sandbox

# ── Stripe (https://dashboard.stripe.com) ────────────────────────────────────
# Use TEST keys (sk_test_...) for sandbox; switch to LIVE keys for production.
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ── Frontend environment variables (prefixed EXPO_PUBLIC_) ───────────────────
# The base URL of the API server, as seen from the frontend.
# In Replit, look at the "API Server" artifact preview URL, e.g.:
#   https://<your-repl>.replit.dev/api-server
# Leave empty to use relative paths (only works when both are on the same origin).
EXPO_PUBLIC_API_BASE_URL=https://your-repl.replit.dev/api-server

# ── Stripe publishable key (frontend, safe to expose) ────────────────────────
# From: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Database (auto-provisioned by Replit) ─────────────────────────────────────
# This is set automatically when you provision a PostgreSQL database in Replit.
# You don't need to set this manually in development.
DATABASE_URL=postgresql://user:password@localhost:5432/financedb

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Replit. Do not override.
# PORT=3000
