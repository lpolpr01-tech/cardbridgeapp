# ============================================================
# CardBridge — environment variable template
#
# Copy this file to `.env` in the same directory and fill in real values:
#     cp .env.example .env
#
# This template is SAFE to commit to git. The real `.env` is gitignored
# and must never be committed.
# ============================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random 64-char hex string used to sign JWT tokens for the beta user.
# Generate one with: openssl rand -hex 32
JWT_SECRET=your_random_64_char_hex_string_here

# ── Plaid (https://dashboard.plaid.com/developers/keys) ──────────────────────
# Sign up at https://dashboard.plaid.com to get sandbox credentials (free).
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SANDBOX_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox

# ── Stripe (https://dashboard.stripe.com/apikeys) ─────────────────────────────
# Use a test-mode key (starts with `sk_test_`). Never commit a live key.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the Expo app uses to reach this API server.
# - For iOS Simulator / Android Emulator on the same machine: http://localhost:3000
# - For a physical iPhone via Expo Go: use your machine's LAN IP, e.g. http://192.168.1.13:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Stripe publishable key (starts with `pk_test_`) — exposed to the client app, safe to ship.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── Anthropic AI (optional — only needed for the in-app AI chat feature) ──────
# Leave as placeholder if you don't need the AI agent. Payment features work without it.
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# In sandbox/dev, a placeholder URL is fine — the JWT auth path never queries
# the database, so no real connection is made. Set a real URL for production.
DATABASE_URL=postgresql://user:password@localhost:5432/cardbridge
